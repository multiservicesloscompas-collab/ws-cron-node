{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node", "vitest/globals"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "main.ts",
    "app/**/*.ts",
    "domain/**/*.ts",
    "infra/**/*.ts",
    "scripts/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": ["node_modules", "app/web/__test__/make-web-server.test.ts"]
}
